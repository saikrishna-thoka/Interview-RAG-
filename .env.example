# Client-side Supabase keys (prefixed with VITE_ for Vite bundling)
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-client-anon-key

# Service-side Supabase keys (keep secure, only for private servers if needed)
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Client-side Groq API key
VITE_GROQ_API_KEY=your-groq-api-key
